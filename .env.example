# ── Copy this file to .env and fill in your values ──────────────────────────

# ── Windchill Server (required for real data sync) ───────────────────────────
WC_BASE_URL=https://your-windchill-server.company.com
WC_USERNAME=your_windchill_username
WC_PASSWORD=your_windchill_password
# Set to false if your server uses a self-signed SSL certificate
WC_SSL_VERIFY=true

# ── LLM Provider — pick ONE block below ─────────────────────────────────────

# Option 1: Anthropic API direct (default)
LLM_PROVIDER=claude
ANTHROPIC_API_KEY=sk-ant-...
CLAUDE_MODEL=claude-sonnet-4-6

# Option 2: LiteLLM proxy (OpenAI-compatible /chat/completions endpoint)
# LLM_PROVIDER=litellm
# LITELLM_URL=https://litellm.company.com/chat/completions
# LITELLM_MODEL=claude-sonnet-4-6    # model name as registered in your LiteLLM config
# LITELLM_API_KEY=your-litellm-api-key
# LITELLM_SSL_VERIFY=true

# ── Authentication & ACL ────────────────────────────────────────────────────
# none      → no auth (local dev only — API is open)
# apikey    → static API keys per user/team
# windchill → caller supplies their own Windchill credentials; results are
#             ACL-filtered to only show objects they can see in Windchill
AUTH_MODE=none

# Required when AUTH_MODE=apikey — comma-separated username:key pairs
# API_KEYS=alice:sk-alice-abc123,bob:sk-bob-xyz789,readonly:sk-ro-000000

# CORS — restrict to your internal frontend origins in production
# CORS_ORIGINS=https://plm-assistant.company.com,https://internal.company.com

# ── Qdrant vector DB (default: local Docker) ─────────────────────────────────
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=windchill_poc

# Embedding model (sentence-transformers, runs locally)
EMBED_MODEL=sentence-transformers/all-MiniLM-L6-v2

# RAG settings
TOP_K_RESULTS=6
MAX_CONTEXT_CHARS=8000
