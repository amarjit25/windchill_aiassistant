# ── Copy this file to .env and fill in your values ──────────────────────────

# ── Windchill Server (required for real data sync) ───────────────────────────
WC_BASE_URL=https://your-windchill-server.company.com
WC_USERNAME=your_windchill_username
WC_PASSWORD=your_windchill_password
# Set to false if your server uses a self-signed SSL certificate
WC_SSL_VERIFY=true

# Anthropic / Claude (required)
ANTHROPIC_API_KEY=sk-ant-...

# Claude model to use for RAG generation
# Options: claude-opus-4-8 | claude-sonnet-4-6 | claude-haiku-4-5
CLAUDE_MODEL=claude-opus-4-8

# Qdrant vector DB (default: local Docker)
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=windchill_poc

# Embedding model (sentence-transformers, runs locally)
EMBED_MODEL=sentence-transformers/all-MiniLM-L6-v2

# RAG settings
TOP_K_RESULTS=6
MAX_CONTEXT_CHARS=8000
